    // -----------------------------------------------------------------------
    // Static helper methods: hasPresenceEvents / hasTypingEvents / hasEvents
    // -----------------------------------------------------------------------

    @Test
    public void testHasPresenceEventsTrue() {
        StructuredMessage msg = new StructuredMessage();
        msg.setEvents(Collections.singletonList(
                new MessageEvent().eventType(EventTypeEnum.PRESENCE)
                        .presence(new EventPresence().type(EventPresenceType.JOIN))
        ));
        assertTrue(WebMessagingClient.hasPresenceEvents(msg));
    }

    @Test
    public void testHasPresenceEventsFalse() {
        StructuredMessage msg = new StructuredMessage();
        msg.setEvents(Collections.singletonList(
                new MessageEvent().eventType(EventTypeEnum.TYPING)
                        .typing(new EventTyping().type(EventTypingType.ON))
        ));
        assertFalse(WebMessagingClient.hasPresenceEvents(msg));
    }

    @Test
    public void testHasTypingEventsTrue() {
        StructuredMessage msg = new StructuredMessage();
        msg.setEvents(Collections.singletonList(
                new MessageEvent().eventType(EventTypeEnum.TYPING)
                        .typing(new EventTyping().type(EventTypingType.ON))
        ));
        assertTrue(WebMessagingClient.hasTypingEvents(msg));
    }

    @Test
    public void testHasTypingEventsFalse() {
        StructuredMessage msg = new StructuredMessage();
        msg.setEvents(Collections.singletonList(
                new MessageEvent().eventType(EventTypeEnum.PRESENCE)
        ));
        assertFalse(WebMessagingClient.hasTypingEvents(msg));
    }

    @Test
    public void testHasEventsEmptyList() {
        StructuredMessage msg = new StructuredMessage();
        msg.setEvents(new ArrayList<>());
        assertFalse(WebMessagingClient.hasEvents(msg, EventTypeEnum.TYPING));
        assertFalse(WebMessagingClient.hasEvents(msg, EventTypeEnum.PRESENCE));
    }

    @Test
    public void testHasEventsMultipleEvents() {
        StructuredMessage msg = new StructuredMessage();
        msg.setEvents(Arrays.asList(
                new MessageEvent().eventType(EventTypeEnum.TYPING),
                new MessageEvent().eventType(EventTypeEnum.PRESENCE)
        ));
        assertTrue(WebMessagingClient.hasEvents(msg, EventTypeEnum.TYPING));
        assertTrue(WebMessagingClient.hasEvents(msg, EventTypeEnum.PRESENCE));
        assertFalse(WebMessagingClient.hasEvents(msg, EventTypeEnum.COBROWSE));
    }

