    @Test
    public void testIsMimeTypeAllowedInbound() {
        FileUploadMode mode = new FileUploadMode();
        mode.setFileTypes(Arrays.asList(
                new FileType().type("image/png"),
                new FileType().type("application/pdf")
        ));
        AllowedMedia media = new AllowedMedia().inbound(mode);
        client.setAllowedMediaInbound(media);

        assertTrue(client.isMimeTypeAllowedInbound("image/png"));
        assertTrue(client.isMimeTypeAllowedInbound("application/pdf"));
        assertFalse(client.isMimeTypeAllowedInbound("video/mp4"));
    }

