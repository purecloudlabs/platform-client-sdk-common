    // -----------------------------------------------------------------------
    // Full usage scenario (mocked WebSocket)
    // -----------------------------------------------------------------------

    /**
     * Simulates a typical client lifecycle:
     * create client → set ApiClient → register listener → "connect" →
     * configure session → send typing → send message → disconnect.
     *
     * The WebSocket is mocked so no real network call is made, but we
     * verify every payload that would go over the wire, in order.
     */
    @Test
    public void testTypicalUsageScenario() throws Exception {
        // 1. Create client
        WebMessagingClient scenarioClient = new WebMessagingClient(GenesysCloudRegionWebSocketHosts.us_east_1);

        // 2. Build and set an ApiClient with retry configuration
        ApiClient.RetryConfiguration retryConfiguration = new ApiClient.RetryConfiguration();
        retryConfiguration.setMaxRetryTimeSec(30);
        ApiClient apiClient = ApiClient.Builder.standard()
                .withRetryConfiguration(retryConfiguration)
                .withConnectionTimeout(10)
                .build();
        scenarioClient.setApiClient(apiClient);

        // 3. Register a session listener to capture events
        AtomicReference<SessionResponse> capturedSession = new AtomicReference<>();
        AtomicReference<StructuredMessage> capturedMessage = new AtomicReference<>();
        AtomicBoolean wsConnected = new AtomicBoolean(false);
        AtomicBoolean wsDisconnected = new AtomicBoolean(false);

        scenarioClient.addSessionListener(new WebMessagingClient.SessionListener() {
            @Override
            public void sessionResponse(SessionResponse response, String rawMessage) {
                capturedSession.set(response);
            }
            @Override
            public void structuredMessage(StructuredMessage message, String rawMessage) {
                capturedMessage.set(message);
            }
            @Override public void presignedUrlResponse(PresignedUrlResponse r, String raw) {}
            @Override public void uploadSuccessEvent(UploadSuccessEvent e, String raw) {}
            @Override public void uploadFailureEvent(UploadFailureEvent e, String raw) {}
            @Override public void connectionClosedEvent(ConnectionClosedEvent e, String raw) {}
            @Override public void sessionExpiredEvent(SessionExpiredEvent e, String raw) {}
            @Override public void sessionClearedEvent(SessionClearedEvent e, String raw) {}
            @Override public void jwtResponse(JwtResponse r, String raw) {}
            @Override public void getConfigurationResponse(GetConfigurationResponse r, String raw) {}
            @Override public void unexpectedMessage(BaseMessage m, String raw) {}
            @Override
            public void webSocketConnected() {
                wsConnected.set(true);
            }
            @Override
            public void webSocketDisconnected(int statusCode, String reason) {
                wsDisconnected.set(true);
            }
            @Override public void webSocketError(String reason) {}
        });

        // 4. Simulate the WebSocket being connected (normally done by connect())
        WebSocket mockWs = mock(WebSocket.class);
        when(mockWs.sendText(anyString(), anyBoolean()))
                .thenReturn(CompletableFuture.completedFuture(mockWs));
        when(mockWs.sendClose(anyInt(), anyString()))
                .thenReturn(CompletableFuture.completedFuture(mockWs));
        setField(scenarioClient, "webSocket", mockWs);

        // 5. Configure session
        String deploymentId = "my-deployment-id";
        String origin = "example.com";
        boolean configured = scenarioClient.configureSession(deploymentId, origin);
        assertTrue(configured, "configureSession should succeed");

        // Verify the configure payload
        ArgumentCaptor<String> captor = ArgumentCaptor.forClass(String.class);
        verify(mockWs).sendText(captor.capture(), eq(true));
        String configurePayload = captor.getValue();
        assertTrue(configurePayload.contains("\"action\":\"configureSession\""));
        assertTrue(configurePayload.contains("\"deploymentId\":\"my-deployment-id\""));

        // 6. Send typing indicator
        reset(mockWs);
        when(mockWs.sendText(anyString(), anyBoolean()))
                .thenReturn(CompletableFuture.completedFuture(mockWs));
        setField(scenarioClient, "token", "session-token");

        scenarioClient.sendTypingEvent();

        captor = ArgumentCaptor.forClass(String.class);
        verify(mockWs).sendText(captor.capture(), eq(true));
        String typingPayload = captor.getValue();
        assertTrue(typingPayload.contains("\"eventType\":\"Typing\""));
        assertTrue(typingPayload.contains("\"type\":\"On\""));

        // 7. Send a message
        reset(mockWs);
        when(mockWs.sendText(anyString(), anyBoolean()))
                .thenReturn(CompletableFuture.completedFuture(mockWs));

        scenarioClient.sendMessage("quick, to the batmobile !");

        captor = ArgumentCaptor.forClass(String.class);
        verify(mockWs).sendText(captor.capture(), eq(true));
        String messagePayload = captor.getValue();
        assertTrue(messagePayload.contains("\"text\":\"quick, to the batmobile !\""));
        assertTrue(messagePayload.contains("\"action\":\"onMessage\""));
        assertTrue(messagePayload.contains("\"type\":\"Text\""));

        // 8. Disconnect
        when(mockWs.sendClose(anyInt(), anyString()))
                .thenReturn(CompletableFuture.completedFuture(mockWs));
        scenarioClient.disconnect();
        verify(mockWs).sendClose(eq(1000), eq("Guest client disconnect"));
    }

    // -----------------------------------------------------------------------
    // Helper
    // -----------------------------------------------------------------------

    private WebMessagingClient.SessionListener createNoOpListener() {
        return new WebMessagingClient.SessionListener() {
            public void sessionResponse(SessionResponse r, String raw) {}
            public void structuredMessage(StructuredMessage m, String raw) {}
            public void presignedUrlResponse(PresignedUrlResponse r, String raw) {}
            public void uploadSuccessEvent(UploadSuccessEvent e, String raw) {}
            public void uploadFailureEvent(UploadFailureEvent e, String raw) {}
            public void connectionClosedEvent(ConnectionClosedEvent e, String raw) {}
            public void sessionExpiredEvent(SessionExpiredEvent e, String raw) {}
            public void sessionClearedEvent(SessionClearedEvent e, String raw) {}
            public void jwtResponse(JwtResponse r, String raw) {}
            public void getConfigurationResponse(GetConfigurationResponse r, String raw) {}
            public void unexpectedMessage(BaseMessage m, String raw) {}
            public void webSocketConnected() {}
            public void webSocketDisconnected(int code, String reason) {}
            public void webSocketError(String reason) {}
        };
    }
